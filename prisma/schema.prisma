generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Funcionario {
  id              Int               @id @default(autoincrement())
  nome            String            @db.VarChar(100)
  tipo            String            @db.VarChar(50)
  extras          String?           @default("00:00") @db.VarChar(10)
  faltas          Int?              @default(0)
  ativo           Boolean?          @default(true)
  registros_ponto RegistroPonto[]
  log_registros   LogRegistro[]
  comentarios     Comentario[]
  ajustes_saldo   AjusteSaldo[]
  usuario         Usuario?

  @@map("funcionarios")
}

model LogRegistro {
  id             Int       @id @default(autoincrement())
  funcionarioId  Int       @map("funcionario_id")
  dataRegistro   DateTime? @map("data_registro") @db.Date
  usuario        String    @db.VarChar(50)
  acao           String    @db.VarChar(20)
  campoAlterado  String?   @map("campo_alterado") @db.VarChar(20)
  valorAnterior  String?   @map("valor_anterior") @db.VarChar(20)
  valorNovo      String?   @map("valor_novo") @db.VarChar(20)
  criadoEm       DateTime? @default(now()) @map("criado_em") @db.Timestamp(6)
  funcionario    Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("log_registros")
}

model RegistroPonto {
  id            Int         @id @default(autoincrement())
  funcionarioId Int         @map("funcionario_id")
  data          DateTime    @db.Date
  e1            DateTime?   @db.Time(6)
  s1            DateTime?   @db.Time(6)
  e2            DateTime?   @db.Time(6)
  s2            DateTime?   @db.Time(6)
  e3            DateTime?   @db.Time(6)
  s3            DateTime?   @db.Time(6)
  total         String?     @db.VarChar(10)
  extras        String?     @db.VarChar(10)
  negativos     String?     @db.VarChar(10)
  evento        String?     @db.VarChar(20)
  noturno       String?     @db.VarChar(10)
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([funcionarioId, data])
  @@map("registros_ponto")
}

model Usuario {
  id            Int          @id @default(autoincrement())
  nome          String       @db.VarChar(100)
  login         String       @unique @db.VarChar(50)
  senha         String       @db.VarChar(255)
  perfil        String       @default("RH") @db.VarChar(20) // Admin, RH, Gestor, Contador
  funcionarioId Int?         @unique @map("funcionario_id")
  criadoEm      DateTime?    @default(now()) @map("criado_em") @db.Timestamp(6)
  
  funcionario   Funcionario? @relation(fields: [funcionarioId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  comentarios   Comentario[]
  ajustes_saldo AjusteSaldo[]

  @@map("usuarios")
}

model Comentario {
  id              Int         @id @default(autoincrement())
  texto           String      @db.Text
  tipo            String      @db.VarChar(20) // 'DIARIO' or 'GERAL'
  dataReferencia  DateTime?   @map("data_referencia") @db.Date
  funcionarioId   Int         @map("funcionario_id")
  usuarioId       Int         @map("usuario_id")
  criadoEm        DateTime    @default(now()) @map("criado_em") @db.Timestamp(6)

  funcionario     Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  usuario         Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("comentarios")
}

model AjusteSaldo {
  id              Int         @id @default(autoincrement())
  funcionarioId   Int         @map("funcionario_id")
  usuarioId       Int         @map("usuario_id")
  valor           String      @db.VarChar(10) // e.g. "+02:00" or "-05:00"
  motivo          String      @db.VarChar(255)
  data            DateTime    @default(now()) @db.Timestamp(6)

  funcionario     Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  usuario         Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("ajustes_saldo")
}
