# ============================================
# BANCO DE DADOS (PRODUÇÃO)
# ============================================
# Para Railway: obtenha da interface do Railway
# Formato: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/ponto_eletronico

# ============================================
# AMBIENTE
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# LEGADO (não usar em produção)
# ============================================
# Estes devem ser substituídos por DATABASE_URL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ponto_eletronico
DB_USER=postgres
DB_PASSWORD=seu_password_aqui

# ============================================
# NOTA DE SEGURANÇA
# ============================================
# NUNCA committe o arquivo .env para o Git!
# Use apenas .env.example com valores de exemplo.
# Credenciais reais devem ser:
# - Definidas como variáveis de ambiente no servidor
# - Armazenadas em .env (que está em .gitignore)
# - Nunca hardcoded no código
